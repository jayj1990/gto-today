# App
NEXT_PUBLIC_APP_URL=http://localhost:3000
NEXT_PUBLIC_APP_NAME="gto.today"

# Auth.js v5
AUTH_SECRET=
AUTH_TRUST_HOST=true
AUTH_GOOGLE_ID=
AUTH_GOOGLE_SECRET=
AUTH_APPLE_ID=
AUTH_APPLE_SECRET=
# Kakao / Naver — optional, provider registers only when BOTH set.
# See docs/oauth-setup.md for console registration steps.
KAKAO_CLIENT_ID=
KAKAO_CLIENT_SECRET=
NAVER_CLIENT_ID=
NAVER_CLIENT_SECRET=
AUTH_EMAIL_FROM="no-reply@gto.today"
AUTH_RESEND_KEY=

# Neon Postgres
DATABASE_URL=

# Upstash Redis (cache + ratelimit)
UPSTASH_REDIS_REST_URL=
UPSTASH_REDIS_REST_TOKEN=

# Anthropic (Claude Haiku 4.5 for explanations)
ANTHROPIC_API_KEY=

# Sentry (optional, client + server). NEXT_PUBLIC_SENTRY_DSN ships to
# the browser bundle; SENTRY_DSN is server-only. Usually the same DSN.
# Without either set, Sentry init is a no-op and adds no runtime cost.
SENTRY_DSN=
NEXT_PUBLIC_SENTRY_DSN=
