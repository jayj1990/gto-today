# Solver runtime artifacts — deterministic outputs of the generator
# scripts, not worth committing (bloats repo, regenerates anyway).
inputs/
outputs/
batch.log
watchdog.log
*.log
# nohup stdout streams from background chain runs
*.out
# Ad-hoc input drafts at the solver-run root — canonical inputs live
# under inputs/ and are regenerated by scripts/gen-input.mjs. Keep
# subdir txts (e.g. inputs-retry/) so hand-crafted recovery files
# stay versioned.
/*.txt
