auto-install-peers=true
enable-pre-post-scripts=true
shamefully-hoist=false
strict-peer-dependencies=false
prefer-workspace-packages=true
link-workspace-packages=true
save-workspace-protocol=rolling

# @jayj1990 scope lives on GitHub Packages (solver-wasm). Token is
# read from NODE_AUTH_TOKEN env var — set in Vercel as Sensitive and
# exported locally when running `pnpm install` for WASM bumps.
@jayj1990:registry=https://npm.pkg.github.com
//npm.pkg.github.com/:_authToken=${NODE_AUTH_TOKEN}
