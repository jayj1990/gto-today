// Prisma schema for gto.today
// Keeps the stock Auth.js v5 model (User/Account/Session/VerificationToken)
// so any official adapter doc applies cleanly. Extra domain tables
// (streaks, solved history) will land in later phases.

generator client {
  provider      = "prisma-client-js"
  // Generate engines for the local OS AND the Linux runtime Vercel
  // uses. Without rhel-openssl-3.0.x, production functions throw
  // 'Query engine not found' at first DB call.
  binaryTargets = ["native", "rhel-openssl-3.0.x"]
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id            String    @id @default(cuid())
  name          String?
  email         String    @unique
  emailVerified DateTime?
  image         String?
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  accounts Account[]
  sessions Session[]
}

model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String? @db.Text
  access_token      String? @db.Text
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String? @db.Text
  session_state     String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
  // Account lookups and listings are always keyed by userId; without
  // an index Postgres scans the whole table on every session-sync
  // round-trip.
  @@index([userId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  // Auth.js runs an expired-session sweep; indexing `expires` turns
  // that into a range scan instead of a full-table read.
  @@index([expires])
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
  @@index([expires])
}
